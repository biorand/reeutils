<Window x:Class="ReeCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReeCompare"
        mc:Ignorable="d"
        Title="RszCompare" Height="800" Width="1400"
        Background="#1E1E1E" Foreground="#CCCCCC"
        Icon="Resources/icon.png"
        FontFamily="Segoe UI, Consolas">
    
    <Window.Resources>
        <!-- VS Code Colors -->
        <SolidColorBrush x:Key="ActivityBarBackground" Color="#333333"/>
        <SolidColorBrush x:Key="SideBarBackground" Color="#252526"/>
        <SolidColorBrush x:Key="EditorBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="StatusBarBackground" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextForeground" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="HeaderForeground" Color="#E7E7E7"/>
        <SolidColorBrush x:Key="ListHover" Color="#2A2D2E"/>
        <SolidColorBrush x:Key="ListSelected" Color="#37373D"/>
        
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                         <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu Style -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <!-- TreeView Style -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource SideBarBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource EditorBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="RowBackground" Value="{StaticResource EditorBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#404040"/>
            <Setter Property="VerticalGridLinesBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                     <Setter Property="Background" Value="{StaticResource ListSelected}"/>
                     <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Search Styles -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SearchToggleButton" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Name="Border" Background="Transparent" Padding="5,2" CornerRadius="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#454545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Search Panel -->
            <RowDefinition Height="*"/>     <!-- Main Content -->
            <RowDefinition Height="22"/>    <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderThickness="0,0,0,1" BorderBrush="{StaticResource PanelBorder}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search Box -->
                    <ColumnDefinition Width="Auto"/> <!-- Options -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Navigation/Actions -->
                </Grid.ColumnDefinitions>
                
                <!-- Search Box -->
                <Grid Grid.Column="0" Width="300" Margin="0,0,15,0">
                    <TextBox Name="TxtSearch" Style="{StaticResource SearchTextBox}" Tag="Enter property name or value..." 
                             TextChanged="TxtSearch_TextChanged" Height="28"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0" Foreground="#888888" IsHitTestVisible="False"/>
                    <TextBlock Text="Search..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="#888888" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Combined Search Options -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Checkboxes -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                        <CheckBox Name="SearchChkMatchCase" Content="Aa" ToolTip="Match Case" Style="{StaticResource SearchToggleButton}" Margin="0,0,5,0" Checked="SearchOption_Changed" Unchecked="SearchOption_Changed" Width="30" HorizontalContentAlignment="Center"/>
                        <CheckBox Name="SearchChkRegex" Content=".*" ToolTip="Use Regular Expression" Style="{StaticResource SearchToggleButton}" Margin="0,0,5,0" Checked="SearchOption_Changed" Unchecked="SearchOption_Changed" Width="30" HorizontalContentAlignment="Center"/>
                        <CheckBox Name="SearchChkDiffOnly" Content="Diffs" ToolTip="Start items with differences only" Style="{StaticResource SearchToggleButton}" Checked="SearchOption_Changed" Unchecked="SearchOption_Changed"/>
                    </StackPanel>

                    <!-- Radio Buttons -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Name="SearchRadPropName" Content="Name" Foreground="#BBBBBB" VerticalAlignment="Center" Margin="0,0,10,0" IsChecked="True" Checked="SearchOption_Changed"/>
                        <RadioButton Name="SearchRadPropValue" Content="Value" Foreground="#BBBBBB" VerticalAlignment="Center" Margin="0,0,10,0" Checked="SearchOption_Changed"/>
                        <RadioButton Name="SearchRadBoth" Content="Both" Foreground="#BBBBBB" VerticalAlignment="Center" Checked="SearchOption_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation & Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Name="BtnPrev" Content="◀" ToolTip="Previous Match" Click="BtnPrev_Click" Style="{x:Null}" Background="Transparent" Foreground="#888888" Margin="0,0,5,0" Padding="5"/>
                    <TextBlock Name="TxtMatchStatus" Text="0/0" VerticalAlignment="Center" Margin="5,0" Foreground="#888888" Width="40" TextAlignment="Center"/>
                    <Button Name="BtnNext" Content="▶" ToolTip="Next Match" Click="BtnNext_Click" Style="{x:Null}" Background="Transparent" Foreground="#888888" Margin="5,0,0,0" Padding="5"/>
                    
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="15,5"/>
                    
                    <Button Content="Clear" Click="BtnClearSearch_Click" Background="Transparent" Foreground="#888888" Margin="0,0,5,0"/>
                    <Button Content="Save" Click="BtnSaveSearch_Click" Margin="0,0,5,0" Background="Transparent" Foreground="#007ACC" ToolTip="Save to History"/>
                    
                    <!-- History Toggle -->
                    <ToggleButton Name="BtnHistory" Content="History ▼" Click="BtnHistory_Click" Background="Transparent" Foreground="#CCCCCC" BorderThickness="0"/>
                    <Popup Name="PopHistory" PlacementTarget="{Binding ElementName=BtnHistory}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Closed="PopHistory_Closed">
                        <Border Background="#2D2D30" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="0" Margin="0,5,0,0" Width="300" MaxHeight="400">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Recent Searches" Foreground="#888888" FontSize="11" Margin="10,5"/>
                                <ListBox Name="ListHistory" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="#CCCCCC" SelectionChanged="ListHistory_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>  <!-- Side Bar (File A) -->
                <ColumnDefinition Width="5"/>    <!-- Splitter -->
                <ColumnDefinition Width="*"/>    <!-- Editor (Diff) -->
                <ColumnDefinition Width="5"/>    <!-- Splitter -->
                <ColumnDefinition Width="300"/>  <!-- Side Bar (File B - Optional/Right) -->
            </Grid.ColumnDefinitions>

            <!-- Side Bar (File A Explorer) -->
            <Grid Grid.Column="0" Background="{StaticResource SideBarBackground}" AllowDrop="True" Drop="FileA_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Margin="10,10,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="EXPLORER: FILE A" Foreground="#BBBBBB" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Load RSZ" Click="LoadRsz_Click" Background="Transparent" Foreground="#007ACC" Padding="5,0" FontSize="11" ToolTip="Load RSZ JSON Definitions"/>
                </Grid>
                
                <StackPanel Grid.Row="1" Margin="10,0,10,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="BtnLoadA" Content="Open File A" Click="BtnLoadA_Click" Background="#3C3C3C" Foreground="#CCCCCC" HorizontalContentAlignment="Left" Height="25"/>
                        <ToggleButton Name="BtnRecent" Grid.Column="1" Content="&#xE81C;" FontFamily="Segoe MDL2 Assets" Width="25" Height="25" Background="#3C3C3C" Foreground="#CCCCCC" Margin="2,0,0,0" ToolTip="Recent Files" Click="BtnRecent_Click"/>
                    </Grid>
                    <TextBlock Name="TxtFileA" Text="No file loaded" Foreground="#888888" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>

                    <Popup Name="PopRecent" PlacementTarget="{Binding ElementName=BtnRecent}" StaysOpen="False" IsOpen="False" PopupAnimation="Slide" AllowsTransparency="True">
                        <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Padding="5">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="RECENT COMPARISONS" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="5"/>
                                <ListBox Name="ListRecent" Grid.Row="1" Background="Transparent" BorderThickness="0" MaxHeight="200" Width="300" SelectionChanged="ListRecent_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" Foreground="#CCCCCC" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>

                <TreeView Name="TreeA" Grid.Row="2" SelectedItemChanged="TreeA_SelectedItemChanged" BorderThickness="0">
                     <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="Visibility" Value="{Binding NodeVisibility}"/>
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                     <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" Foreground="DeepSkyBlue" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                                    <Setter Property="Background" Value="#3498db"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding MatchCount, Converter={local:InverseBoolToVisibilityConverter}, ConverterParameter=hideIfZero}">
                                     <TextBlock Text="{Binding MatchCount}" Foreground="White" FontSize="10"/>
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
            
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource PanelBorder}"/>

            <!-- Editor Area (Diff) -->
            <Grid Grid.Column="2" Background="{StaticResource EditorBackground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/> <!-- Tab Header -->
                     <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Mock Tab Bar -->
                <Border Grid.Row="0" Background="#252526" BorderThickness="0,0,0,1" BorderBrush="{StaticResource PanelBorder}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1E1E1E" Padding="15,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Comparison" Foreground="#E7E7E7" VerticalAlignment="Center"/>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#888888" Margin="10,0,0,0" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <DataGrid Name="GridDiff" Grid.Row="1" IsReadOnly="True" BorderThickness="0" Background="Transparent" RowBackground="Transparent">
                     <DataGrid.Columns>
                        <DataGridTextColumn Header="COMPONENT" Binding="{Binding ComponentName}" Width="150" Foreground="#569CD6">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="PROPERTY" Binding="{Binding FieldName}" Width="150">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#9CDCFE"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNameMatch}" Value="True">
                                            <Setter Property="Background" Value="#264F78"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="LEFT VALUE" Binding="{Binding ValueA}" Width="*">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#CE9178"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValueAMatch}" Value="True">
                                            <Setter Property="Background" Value="#264F78"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="RIGHT VALUE" Binding="{Binding ValueB}" Width="*">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#CE9178"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValueBMatch}" Value="True">
                                            <Setter Property="Background" Value="#673604"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                
                <TextBlock Text="Select an object in both trees to view differences" 
                           Foreground="#555555" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasItems, ElementName=GridDiff, Converter={local:InverseBoolToVisibilityConverter}}"/>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{StaticResource PanelBorder}"/>

            <!-- Right Sidebar (File B Explorer) -->
            <Grid Grid.Column="4" Background="{StaticResource SideBarBackground}" AllowDrop="True" Drop="FileB_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="EXPLORER: FILE B" Foreground="#BBBBBB" FontSize="11" Margin="20,10,0,10" FontWeight="Bold"/>

                <StackPanel Grid.Row="1" Margin="10,0,10,10">
                    <Button Name="BtnLoadB" Content="Open File B" Click="BtnLoadB_Click" Background="#3C3C3C" Foreground="#CCCCCC" HorizontalContentAlignment="Left"/>
                    <TextBlock Name="TxtFileB" Text="No file loaded" Foreground="#888888" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>

                <TreeView Name="TreeB" Grid.Row="2" SelectedItemChanged="TreeB_SelectedItemChanged" BorderThickness="0">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="Visibility" Value="{Binding NodeVisibility}"/>
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" Foreground="Orange" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                                    <Setter Property="Background" Value="#e67e22"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Style="{StaticResource BadgeStyle}" Visibility="{Binding MatchCount, Converter={local:InverseBoolToVisibilityConverter}, ConverterParameter=hideIfZero}">
                                     <TextBlock Text="{Binding MatchCount}" Foreground="White" FontSize="10"/>
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBackground}">
            <DockPanel LastChildFill="False">
                <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="12"/>
                <TextBlock Text="Ready" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,10,0">
                     <TextBlock Text="UTF-8" Foreground="White" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
                     <TextBlock Text="JSON" Foreground="White" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

