<UserControl x:Class="RszViewer.LinkTracerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RszViewer"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <local:LinkIconConverter x:Key="LinkIconConverter"/>
        <local:PathToNameConverter x:Key="PathToNameConverter"/>
    </UserControl.Resources>
    
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="15,10" BorderThickness="0,0,0,1" BorderBrush="#3F3F46">
            <StackPanel>
                <TextBlock Text="RSZ LINK (OBJECT DEPENDENCY MAPPER)" Foreground="#007ACC" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Target Folder:" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                    <TextBox Name="TxtFolderPath" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Background="#3C3C3C" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" Padding="5,0"/>
                    <Button Name="BtnBrowse" Grid.Column="2" Content="Browse" Click="BtnBrowse_Click" Margin="5,0,0,0" Width="80" Padding="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Source Object Info (if any) -->
        <Border Grid.Row="1" Background="#252526" Padding="15,5" BorderThickness="0,0,0,1" BorderBrush="#3F3F46">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Source Object:" Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock Name="TxtSourceName" Text="[None Selected]" Foreground="White" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                <TextBlock Text="GUID:" Foreground="#888888" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <TextBlock Name="TxtSourceGuid" Text="-" Foreground="#007ACC" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="2" Background="#1E1E1E">
            <TreeView Name="TreeResults" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding LinkType, Converter={StaticResource LinkIconConverter}}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FilePath, Converter={StaticResource PathToNameConverter}}" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ObjectName}" Foreground="#569CD6" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Reason, StringFormat=' ({0})'}" Foreground="#6A9955" FontStyle="Italic" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            
            <!-- Empty State / Progress -->
            <TextBlock Name="TxtNoResults" Text="No dependencies traced." Foreground="#555555" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
            
            <ProgressBar Name="ProgressSearch" Height="4" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#007ACC" IsIndeterminate="True" Visibility="Collapsed"/>
        </Grid>

        <!-- Footer / Controls -->
        <Border Grid.Row="3" Background="#2D2D30" Padding="15,10" BorderThickness="0,1,0,0" BorderBrush="#3F3F46">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="TxtStatus" Text="Ready" Foreground="#888888" VerticalAlignment="Center"/>
                <Button Name="BtnStart" Grid.Column="1" Content="Start Tracing" Click="BtnStart_Click" Width="120" Height="30" FontWeight="Bold" Background="#007ACC"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
