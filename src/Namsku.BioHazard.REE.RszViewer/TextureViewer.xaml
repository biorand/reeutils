<UserControl x:Class="RszViewer.TextureViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BgSecondary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtInfo" Text="Unknown Format" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,20,0" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                
                <CheckBox Content="R" IsChecked="True" Foreground="#FF5555" Margin="0,0,8,0" Click="Channel_Click"/>
                <CheckBox Content="G" IsChecked="True" Foreground="#55FF55" Margin="0,0,8,0" Click="Channel_Click"/>
                <CheckBox Content="B" IsChecked="True" Foreground="#5555FF" Margin="0,0,8,0" Click="Channel_Click"/>
                <CheckBox Content="A" IsChecked="True" Foreground="#AAAAAA" Margin="0,0,20,0" Click="Channel_Click"/>

                <Button Content="-" Click="BtnZoomOut_Click" Style="{StaticResource ProButtonSecondary}" Padding="8,4" Margin="0,0,4,0"/>
                <Button Content="+" Click="BtnZoomIn_Click" Style="{StaticResource ProButtonSecondary}" Padding="8,4" Margin="0,0,10,0"/>

                <Button Content="Export TGA" Click="BtnExport_Click" Style="{StaticResource ProButtonSecondary}" Padding="10,4"/>
            </StackPanel>
        </Border>

        <!-- Image Area -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111111" 
                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel" x:Name="MainScrollViewer">
            <Grid>
                <Grid.Resources>
                    <!-- Checkered Background for Transparency -->
                    <DrawingBrush x:Key="CheckerBrush" Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#181818">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#222222">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,10,10" />
                                            <RectangleGeometry Rect="10,10,10,10" />
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Resources>
                
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                </Grid.LayoutTransform>

                <Rectangle Fill="{StaticResource CheckerBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <Image x:Name="ImgPreview" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
